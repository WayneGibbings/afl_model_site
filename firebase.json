{
  "hosting": {
    "public": "out",
    "cleanUrls": true,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/genie",
        "function": {
          "functionId": "genieProxy",
          "region": "australia-southeast1"
        }
      },
      {
        "source": "/api/site-data/latest",
        "function": {
          "functionId": "siteDataLatest",
          "region": "australia-southeast1"
        }
      },
      {
        "source": "/api/site-data/refresh",
        "function": {
          "functionId": "siteDataRefresh",
          "region": "australia-southeast1"
        }
      }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs22",
    "predeploy": [
      "npm --prefix \"$RESOURCE_DIR\" run build"
    ]
  }
}
